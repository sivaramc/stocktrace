# Copy to deploy/.env on the VPS and fill in. All variables are required
# unless annotated otherwise.

# --- DNS / TLS ---
STOCKTRACE_DOMAIN=api.stocktrace.in
ACME_EMAIL=you@example.com

# --- Docker image (pulled by docker-compose) ---
# Use the :latest tag for rolling updates or pin to a commit SHA for stability.
STOCKTRACE_IMAGE=ghcr.io/sivaramc/stocktrace:latest

# --- Database ---
POSTGRES_DB=stocktrace
POSTGRES_USER=stocktrace
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=REPLACE_ME

# --- App secrets ---
# Generate with: openssl rand -base64 48
STOCKTRACE_JWT_SECRET=REPLACE_ME_MIN_32_BYTES
# JWT lifetime in seconds (default 8h). Optional.
STOCKTRACE_JWT_TTL_SECONDS=28800

# Seeded on first startup. Rotate in-app afterwards.
STOCKTRACE_ADMIN_EMAIL=admin@stocktrace.in
STOCKTRACE_ADMIN_PASSWORD=REPLACE_ME

# Optional Chartink webhook shared secret — leave blank to accept all.
CHARTINK_WEBHOOK_SECRET=
